# Python
__pycache__/
*.pyc
*.pyo
.venv/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Data backups (git tracks current, not historical exports)
data/backups/

# Node
node_modules/
*.tmp
data/*.tmp

# Local run log (./start.sh -d)
aipd.local.log

# Local sync caches (re-fetched from upstream)
data/.cache/

# Fetched / derived artifacts — regenerated on each machine, not versioned.
#   official-api.json  ← `npm run sync`        (genai-prices + litellm + annotations)
#   anyrouter-status.json ← `npm run check-relays`
# Run `npm run sync` after cloning/pulling to populate model data (server falls back to empty until then).
data/official-api.json
data/anyrouter-status.json
#   benchmarks.json ← `npm run sync:bench`  (LMArena Elo + Aider pass-rate, capability axis)
data/benchmarks.json

# PRIVACY: personal billing data stays local (feasibility §2.3 risk #2)
data/subscriptions.json

# PRIVACY: usage-tracking credentials (api keys / cookies) — never commit
# (ignore the dir's *contents*, not the dir itself, so the .example exception below works)
data/credentials/*
!data/credentials/config.json.example

# Experimental / lab — not ready for production
lab/
